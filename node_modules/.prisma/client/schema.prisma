// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enhanced Poker Enums
enum PokerStreet {
  PREFLOP
  FLOP
  TURN
  RIVER
  SHOWDOWN
  FINISHED
}

enum PlayerPosition {
  UTG
  UTG1
  UTG2
  UTG3
  UTG4
  HJ
  CO
  BTN
  SB
  BB
}

enum PayInfoStatus {
  PAY_TILL_END
  ALLIN
  FOLDED
}

enum GameType {
  TEXAS_HOLDEM
  OMAHA
  SEVEN_CARD_STUD
}

enum GameStatus {
  WAITING
  STARTING
  PLAYING
  FINISHED
  CANCELLED
}

enum HandRank {
  HIGH_CARD
  PAIR
  TWO_PAIR
  THREE_OF_A_KIND
  STRAIGHT
  FLUSH
  FULL_HOUSE
  FOUR_OF_A_KIND
  STRAIGHT_FLUSH
  ROYAL_FLUSH
}

enum ActionType {
  FOLD
  CHECK
  CALL
  BET
  RAISE
  ALL_IN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  password     String?
  avatar       String?
  tokenBalance Int      @default(0)
  isOnline     Boolean  @default(false)
  lastSeen     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gamesAsPlayer GamePlayer[]
  transactions  Transaction[]
  friends       Friendship[]  @relation("UserFriends")
  friendsOf     Friendship[]  @relation("FriendOfUser")
  chatMessages  ChatMessage[]

  @@map("users")
}

model Game {
  id            String     @id @default(cuid())
  name          String
  gameType      GameType   @default(TEXAS_HOLDEM)
  maxPlayers    Int        @default(9)
  minBet        Int        @default(10)
  maxBet        Int        @default(1000)
  status        GameStatus @default(WAITING)
  currentHandId String?    @unique

  // Enhanced Poker State
  dealerPosition     Int      @default(0)
  smallBlindPosition Int      @default(1)
  bigBlindPosition   Int      @default(2)
  currentPlayerId    String?
  currentBet         Int      @default(0)
  minRaise           Int      @default(0)
  pot                Int      @default(0)
  sidePots           Json? // Array of side pot objects
  communityCards     String[] @default([])
  deck               String[] @default([])
  entropy            String?
  entropySources     String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  players      GamePlayer[]
  hands        Hand[]
  chatMessages ChatMessage[]
  currentHand  Hand?         @relation("GameCurrentHand", fields: [currentHandId], references: [id])

  @@map("games")
}

model Hand {
  id                 String      @id @default(cuid())
  gameId             String
  handNumber         Int
  street             PokerStreet @default(PREFLOP)
  pot                Int         @default(0)
  sidePots           Json? // Array of side pot objects
  communityCards     String[]
  deck               String[]
  currentBet         Int         @default(0)
  minRaise           Int         @default(0)
  dealerPosition     Int         @default(0)
  smallBlindPosition Int         @default(1)
  bigBlindPosition   Int         @default(2)
  currentPlayerId    String?
  winnerIds          String[]
  entropy            String?
  entropySources     String[]
  startedAt          DateTime    @default(now())
  endedAt            DateTime?

  currentHandForGame Game?        @relation("GameCurrentHand")
  actions            HandAction[]
  game               Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("hands")
}

model HandAction {
  id         String          @id @default(cuid())
  handId     String
  playerId   String
  actionType ActionType
  amount     Int             @default(0)
  street     PokerStreet
  position   PlayerPosition?
  timestamp  DateTime        @default(now())

  hand Hand @relation(fields: [handId], references: [id], onDelete: Cascade)

  @@map("hand_actions")
}

model GamePlayer {
  id               String        @id @default(cuid())
  gameId           String
  playerId         String
  position         Int           @default(0)
  chips            Int           @default(1000)
  isActive         Boolean       @default(true)
  isAllIn          Boolean       @default(false)
  isFolded         Boolean       @default(false)
  holeCards        String[]      @default([])
  handRank         HandRank?
  handValue        Int? // Numeric hand strength
  betAmount        Int           @default(0)
  lastAction       ActionType?
  lastActionAmount Int           @default(0)
  payInfoStatus    PayInfoStatus @default(PAY_TILL_END)
  joinedAt         DateTime      @default(now())
  leftAt           DateTime?

  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player User @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId])
  @@map("game_players")
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String // PURCHASE, BONUS, GAME_WIN, GAME_LOSS
  amount      Int
  balance     Int // User's balance after transaction
  description String?
  metadata    Json? // Additional transaction data
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOfUser", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@map("friendships")
}

model ChatMessage {
  id          String   @id @default(cuid())
  gameId      String?
  userId      String
  message     String
  messageType String   @default("CHAT") // CHAT, SYSTEM, ACTION
  createdAt   DateTime @default(now())

  game Game? @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}
