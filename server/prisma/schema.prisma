// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id        String   @id @default(cuid())
  code      String   @unique // 6-character invite code
  name      String
  isPrivate Boolean  @default(false)
  status    String   @default("waiting") // waiting, playing, finished
  settings  Json     // GameSettings as JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  players Player[]
  games   Game[]

  @@map("rooms")
}

model Player {
  id        String   @id @default(cuid())
  name      String
  chips     Int      @default(1000)
  connected Boolean  @default(true)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  gamePlayers GamePlayer[]
  gameActions GameAction[]

  @@map("players")
}

model Game {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  phase     String   // GamePhase
  status    String   // GameStatus
  pot       Int      @default(0)
  currentBet Int     @default(0)
  dealerIndex Int    @default(0)
  currentPlayerIndex Int @default(0)
  smallBlind Int     @default(10)
  bigBlind   Int     @default(20)
  roundNumber Int    @default(1)
  communityCards Json // Card[] as JSON
  deck       Json    // Card[] as JSON
  provableFairness Json? // ProvableFairnessData as JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  players GamePlayer[]
  actions GameAction[]
  hands   HandHistory[]

  @@map("games")
}

model GamePlayer {
  id        String   @id @default(cuid())
  gameId    String
  playerId  String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  bet       Int      @default(0)
  status    String   // PlayerStatus
  hand      Json     // Card[] as JSON
  isDealer  Boolean  @default(false)
  isSmallBlind Boolean @default(false)
  isBigBlind Boolean @default(false)
  isCurrentTurn Boolean @default(false)
  lastAction String?
  lastActionAmount Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, playerId])
  @@map("game_players")
}

model GameAction {
  id        String   @id @default(cuid())
  gameId    String
  playerId  String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  action    String   // PlayerAction
  amount    Int?
  timestamp DateTime @default(now())

  @@map("game_actions")
}

model HandHistory {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  roundNumber Int
  winners   Json     // Player[] as JSON
  winningHand Json   // Hand as JSON
  pot       Int
  actions   Json     // GameAction[] as JSON
  createdAt DateTime @default(now())

  @@map("hand_history")
} 